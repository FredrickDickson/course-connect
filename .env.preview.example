# CIMA Learning Platform - Preview Environment
# Used for Vercel Preview deployments (branch testing)

# Supabase Configuration (Preview/Staging)
VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-anon-key
VITE_SUPABASE_PROJECT_ID=your-staging-project-id
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# Database (Preview)
DATABASE_URL=postgresql://postgres:password@db.your-staging-project.supabase.co:5432/postgres

# Application (Preview)
NODE_ENV=preview
VITE_APP_URL=https://your-app-git-branch-name.vercel.app
FRONTEND_URL=https://your-app-git-branch-name.vercel.app

# Session Management (Preview)
SESSION_SECRET=your-preview-session-secret-min-32-characters

# Payment Gateway - Test Keys (Preview)
PAYSTACK_SECRET_KEY=sk_test_...
VITE_PAYSTACK_PUBLIC_KEY=pk_test_...

# Email/Notifications (Preview - Test mode)
RESEND_API_KEY=re_test_...

# File Upload (Preview - Staging bucket)
GOOGLE_CLOUD_STORAGE_BUCKET=your-staging-bucket

# Preview-specific flags
VITE_DEBUG_MODE=true
VITE_ENABLE_MOCK_PAYMENTS=false
VITE_ENVIRONMENT=preview
