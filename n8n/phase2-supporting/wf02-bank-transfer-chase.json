    {
      "parameters": {
        "from": "info@thecima.org",
        "to": "={{ $json.user_email }}",
        "subject": "Reminder: Complete Your Bank Transfer - {{ $json.booking_reference }}",
        "html": "<h2>Payment Reminder</h2><p>Dear {{ $json.user_name }},</p><p>This is a friendly reminder about your bank transfer for <strong>{{ $json.course_name }}</strong>.</p><p><strong>Details:</strong></p><ul><li>Amount: GHS {{ $json.amount }}</li><li>Booking Reference: {{ $json.booking_reference }}</li><li>Due: 3 days remaining</li></ul><p>If you've already made the transfer, please forward your receipt to info@thecima.org with your booking reference.</p><p>If you haven't transferred yet, please use these details:</p><p><strong>Bank:</strong> Ghana Commercial Bank<br><strong>Account Name:</strong> Center for International Mediators and Arbitrators<br><strong>Account Number:</strong> 1234567890</p><p>Need help? Call 0536735535 or 0241022964.</p><p>The CIMA Team</p>",
        "options": {}
      },
