{
  "name": "WF02: Bank transfer submitted -> hold spot + chase sequence",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "bank-transfer",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-bank-transfer",
      "name": "Bank Transfer Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "bank-transfer"
    },
    {
      "parameters": {
        "jsCode": "// Verify webhook signature and extract enrollment data\nconst crypto = require('crypto');\n\nconst webhookSecret = $env.SUPABASE_WEBHOOK_SECRET;\nconst signature = $headers['x-webhook-secret'];\n\nif (signature !== webhookSecret) {\n  throw new Error('Invalid webhook signature');\n}\n\n// Check if this is a new enrollment with bank transfer\nconst record = $json.body.record;\nif (record.payment_method !== 'bank_transfer' || record.payment_status !== 'pending_bank') {\n  return [];\n}\n\nreturn [{\n  json: {\n    enrollment_id: record.id,\n    user_id: record.user_id,\n    course_edition_id: record.course_edition_id,\n    user_email: record.user_email,\n    user_name: record.user_name,\n    course_name: record.course_name,\n    amount: record.amount_paid,\n    enrolled_at: record.enrolled_at\n  }\n}];"
      },
      "id": "code-process-webhook",
      "name": "Process Bank Transfer",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "operation": "select",
        "table": "enrollments",
        "columns": "id, booking_reference",
        "where": {
          "conditions": [
            {
              "column": "id",
              "condition": "equal",
              "value": "={{ $json.enrollment_id }}",
              "combinator": "and"
            }
          ]
        },
        "additionalFields": {}
      },
      "id": "supabase-get-enrollment",
      "name": "Get Enrollment Details",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [680, 300],
      "credentials": {
        "supabaseApi": {
          "id": "supabase-service-role",
          "name": "Supabase Service Role"
        }
      }
    },
    {
      "parameters": {
        "from": "info@thecima.org",
        "to": "={{ $json.user_email }}",
        "subject": "Bank Transfer Details - {{ $json.course_name }} - {{ $json.booking_reference }}",
        "html": "<h2>Bank Transfer Payment Instructions</h2><p>Dear {{ $json.user_name }},</p><p>Thank you for enrolling in <strong>{{ $json.course_name }}</strong>.</p><p><strong>Booking Reference:</strong> {{ $json.booking_reference }}</p><p><strong>Amount:</strong> GHS {{ $json.amount }}</p><h3>Bank Details:</h3><p><strong>Bank:</strong> Ghana Commercial Bank<br><strong>Account Name:</strong> Center for International Mediators and Arbitrators<br><strong>Account Number:</strong> 1234567890<br><strong>Branch:</strong> Accra Main</p><h3>Important Notes:</h3><ul><li>Please include your booking reference ({{ $json.booking_reference }}) in the transfer description</li><li>Send payment confirmation to info@thecima.org with your transfer receipt</li><li>Your spot will be held for 5 days from enrollment date</li><li>If payment isn't received within 5 days, your spot may be released to waitlisted students</li></ul><p>After payment confirmation, you'll receive your joining instructions 7 days before the course starts.</p><p>Questions? Call us at 0536735535 or 0241022964.</p><p>Thank you for choosing CIMA!</p><p>The CIMA Team</p>",
        "options": {}
      },
      "id": "resend-bank-details",
      "name": "Send Bank Details Email",
      "type": "n8n-nodes-base.resend",
      "typeVersion": 1,
      "position": [900, 300],
      "credentials": {
        "resendApi": {
          "id": "resend-api",
          "name": "Resend API"
        }
      }
    },
    {
      "parameters": {
        "channel": "#general",
        "text": "Bank transfer initiated: {{ $json.user_name }} - {{ $json.course_name }} (GHS {{ $json.amount }}) - Ref: {{ $json.booking_reference }}",
        "otherOptions": {}
      },
      "id": "slack-admin-notify",
      "name": "Notify Admin (Slack)",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [1120, 300],
      "credentials": {
        "slackApi": {
          "id": "slack-bot-token",
          "name": "Slack Bot Token"
        }
      }
    },
    {
      "parameters": {
        "amount": 2,
        "unit": "days"
      },
      "id": "wait-2-days",
      "name": "Wait 2 Days",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [1340, 300]
    },
    {
      "parameters": {
