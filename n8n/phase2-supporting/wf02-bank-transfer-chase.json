      "id": "supabase-release-spot",
      "name": "Release Spot",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [2880, 300],
      "credentials": {
        "supabaseApi": {
          "id": "supabase-service-role",
          "name": "Supabase Service Role"
        }
      }
    },
    {
      "parameters": {
        "from": "info@thecima.org",
        "to": "={{ $json.user_email }}",
        "subject": "Spot Released - {{ $json.booking_reference }}",
        "html": "<h2>Enrollment Spot Released</h2><p>Dear {{ $json.user_name }},</p><p>We haven't received your bank transfer for <strong>{{ $json.course_name }}</strong> within the 5-day window.</p><p>Your enrollment spot has been released to waitlisted students.</p><p>If you still wish to join this course, you can:</p><ul><li><a href='https://cima.learn/courses/{{ $json.course_edition_id }}'>Re-enroll and pay immediately</a></li><li>Contact us at 0536735535 to discuss payment options</li></ul><p>We hope to see you in a future CIMA course!</p><p>The CIMA Team</p>",
        "options": {}
      },
      "id": "resend-spot-released",
      "name": "Send Spot Released Email",
      "type": "n8n-nodes-base.resend",
