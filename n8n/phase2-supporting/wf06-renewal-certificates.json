              "value": "{{ { amount: $json.amount, renewal_count: $json.renewal_count, certificate_url: $json.certificate_url } }}"
            },
            {
              "column": "created_at",
              "value": "={{ $now }}"
            }
          ]
        },
        "additionalFields": {}
      },
