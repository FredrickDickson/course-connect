{
  "name": "WF21: MCQ auto-grading -> instant result + email",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "assessment-submitted",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-assessment-submitted",
      "name": "Assessment Submitted Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "assessment-submitted"
    },
    {
      "parameters": {
        "jsCode": "// Process assessment submission webhook\nconst crypto = require('crypto');\n\nconst webhookSecret = $env.SUPABASE_WEBHOOK_SECRET;\nconst signature = $headers['x-webhook-secret'];\n\nif (signature !== webhookSecret) {\n  throw new Error('Invalid webhook signature');\n}\n\n// Check if this is a new assessment_submission insertion\nconst record = $json.body.record;\nif (!record || $json.body.type !== 'INSERT' || record.table !== 'assessment_submissions') {\n  return []; // Not a new assessment submission\n}\n\nreturn [{\n  json: {\n    submission_id: record.id,\n    user_id: record.user_id,\n    assessment_id: record.assessment_id,\n    answers: record.answers,\n    submitted_at: record.created_at\n  }\n}];"
      },
      "id": "code-process-assessment",
      "name": "Process Assessment Submission",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "operation": "select",
        "table": "assessments a",
        "columns": "a.*, c.name as course_name, c.course_id",
        "joins": [
          {
            "type": "inner",
            "table": "course_editions ce",
            "on": "a.course_edition_id = ce.id"
          },
          {
            "type": "inner",
            "table": "courses c",
            "on": "ce.course_id = c.id"
          }
        ],
        "where": {
          "conditions": [
            {
              "column": "a.id",
              "condition": "equal",
              "value": "={{ $json.assessment_id }}",
              "combinator": "and"
            }
          ]
        },
        "additionalFields": {}
      },
      "id": "supabase-get-assessment-details",
      "name": "Get Assessment Details",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [680, 300],
      "credentials": {
        "supabaseApi": {
          "id": "supabase-service-role",
          "name": "Supabase Service Role"
        }
      }
    },
    {
      "parameters": {
        "operation": "select",
        "table": "assessment_questions",
        "where": {
          "conditions": [
            {
              "column": "assessment_id",
              "condition": "equal",
              "value": "={{ $json.assessment_id }}",
              "combinator": "and"
            }
          ]
        },
        "orderBy": {
          "field": "question_number",
          "direction": "ASC"
        },
        "additionalFields": {}
      },
      "id": "supabase-get-questions",
      "name": "Get Assessment Questions",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [900, 300],
      "credentials": {
        "supabaseApi": {
          "id": "supabase-service-role",
          "name": "Supabase Service Role"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Calculate MCQ score and generate detailed results\nconst submission = $('Process Assessment Submission').first().json;\nconst assessment = $('Get Assessment Details').first().json;\nconst questions = $('Get Assessment Questions').all() || [];\n\n// Parse student answers\nconst studentAnswers = JSON.parse(submission.answers || '{}');\n\n// Calculate score\nlet correctCount = 0;\nlet totalQuestions = questions.length;\nlet questionResults = [];\n\nquestions.forEach(question => {\n  const questionNumber = question.json.question_number;\n  const correctAnswer = question.json.correct_answer;\n  const studentAnswer = studentAnswers[questionNumber];\n  const isCorrect = studentAnswer === correctAnswer;\n  \n  if (isCorrect) {\n    correctCount++;\n  }\n  \n  questionResults.push({\n    question_number: questionNumber,\n    question_text: question.json.question_text,\n    student_answer: studentAnswer,\n    correct_answer: correctAnswer,\n    is_correct: isCorrect\n  });\n});\n\n// Calculate percentage score\nconst score = Math.round((correctCount / totalQuestions) * 100);\nconst passed = score >= 50; // 50% passing threshold\n\n// Generate feedback based on performance\nlet feedbackMessage = '';\nif (score >= 80) {\n  feedbackMessage = 'Excellent work! You have a strong understanding of the material.';\n} else if (score >= 60) {\n  feedbackMessage = 'Good job! You have a solid grasp of most concepts. Review the questions you missed to improve.';\n} else if (score >= 50) {\n  feedbackMessage = 'You passed! Focus on the areas where you struggled to strengthen your knowledge.';\n} else {\n  feedbackMessage = 'You did not pass this assessment. Please review the material thoroughly and consider retaking the assessment.';\n}\n\nreturn [{\n  json: {\n    submission_id: submission.submission_id,\n    user_id: submission.user_id,\n    assessment_id: submission.assessment_id,\n    assessment_title: assessment.title,\n    course_name: assessment.course_name,\n    total_questions: totalQuestions,\n    correct_answers: correctCount,\n    score: score,\n    passed: passed,\n    feedback_message: feedbackMessage,\n    question_results: questionResults,\n    submitted_at: submission.submitted_at\n  }\n}];"
      },
      "id": "code-calculate-score",
      "name": "Calculate Score + Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "passed-assessment",
              "leftValue": "={{ $json.passed }}",
              "rightValue": "true",
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-passed",
      "name": "Passed Assessment?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "operation": "update",
        "table": "assessment_submissions",
        "columns": {
          "assignment": [
            {
              "column": "score",
              "value": "={{ $json.score }}"
            },
            {
              "column": "passed",
              "value": "={{ $json.passed }}"
            },
            {
              "column": "graded_at",
              "value": "={{ $now }}"
            },
            {
              "column": "feedback",
              "value": "={{ $json.feedback_message }}"
            },
            {
              "column": "question_results",
              "value": "{{ JSON.stringify($json.question_results) }}"
            }
          ]
        },
        "where": {
          "conditions": [
            {
              "column": "id",
              "condition": "equal",
              "value": "={{ $json.submission_id }}",
              "combinator": "and"
            }
          ]
        },
        "additionalFields": {}
      },
      "id": "supabase-update-submission",
      "name": "Update Submission Record",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1560, 300],
      "credentials": {
        "supabaseApi": {
          "id": "supabase-service-role",
          "name": "Supabase Service Role"
        }
      }
    },
    {
      "parameters": {
        "operation": "select",
        "table": "profiles",
        "where": {
          "conditions": [
            {
              "column": "id",
              "condition": "equal",
              "value": "={{ $json.user_id }}",
              "combinator": "and"
            }
          ]
        },
        "additionalFields": {}
      },
      "id": "supabase-get-student-profile",
      "name": "Get Student Profile",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1780, 300],
      "credentials": {
        "supabaseApi": {
          "id": "supabase-service-role",
          "name": "Supabase Service Role"
        }
      }
