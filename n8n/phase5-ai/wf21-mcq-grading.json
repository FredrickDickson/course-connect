    {
      "parameters": {
        "jsCode": "// Generate detailed result email\nconst results = $json;\nconst student = $('Get Student Profile').first().json;\n\n// Generate question breakdown HTML\nconst questionBreakdown = results.question_results.map(q => `\n  <tr style=\"border-bottom: 1px solid #dee2e6;\">\n    <td style=\"padding: 10px; text-align: center;\">${q.question_number}</td>\n    <td style=\"padding: 10px;\">${q.question_text.substring(0, 100)}${q.question_text.length > 100 ? '...' : ''}</td>\n    <td style=\"padding: 10px; text-align: center; font-weight: bold; color: ${q.is_correct ? '#28a745' : '#dc3545'};\">${q.student_answer || 'Not answered'}</td>\n    <td style=\"padding: 10px; text-align: center; font-weight: bold; color: #28a745;\">${q.correct_answer}</td>\n    <td style=\"padding: 10px; text-align: center;\">${q.is_correct ? 'â' : 'â'}</td>\n  </tr>\n`).join('');\n\n// Generate email HTML\nconst emailHtml = `\n  <h2>Assessment Results - ${results.assessment_title}</h2>\n  <p>Dear ${student.full_name},</p>\n  <p>Your assessment has been automatically graded. Here are your results:</p>\n  \n  <div style=\"background: #f8f9fa; padding: 20px; border-radius: 8px; margin: 20px 0; text-align: center;\">\n    <h3 style=\"margin: 0 0 10px 0; color: ${results.passed ? '#28a745' : '#dc3545'};\">${results.passed ? 'â PASSED' : 'â FAILED'}</h3>\n    <div style=\"font-size: 24px; font-weight: bold; margin: 10px 0;\">${results.score}%</div>\n    <div style=\"color: #666;\">${results.correct_answers} out of ${results.total_questions} questions correct</div>\n  </div>\n  \n  <h3>Performance Feedback</h3>\n  <p>${results.feedback_message}</p>\n  \n  <h3>Question Breakdown</h3>\n  <table style=\"width: 100%; border-collapse: collapse; margin: 20px 0;\">\n    <thead>\n      <tr style=\"background: #007bff; color: white;\">\n        <th style=\"padding: 10px; text-align: center;\">#</th>\n        <th style=\"padding: 10px; text-align: left;\">Question</th>\n        <th style=\"padding: 10px; text-align: center;\">Your Answer</th>\n        <th style=\"padding: 10px; text-align: center;\">Correct Answer</th>\n        <th style=\"padding: 10px; text-align: center;\">Result</th>\n      </tr>\n    </thead>\n    <tbody>\n      ${questionBreakdown}\n    </tbody>\n  </table>\n  \n  <h3>Next Steps</h3>\n  ${results.passed \n    ? '<p>Congratulations on passing! You can now proceed to the next course module.</p>'\n    : '<p>Please review the material and consider retaking the assessment. You can retake it after reviewing the questions you missed.</p>'\n  }\n  \n  <p><a href=\"https://cima.learn/assessments/${results.assessment_id}/results\" style=\"background: #007bff; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; display: inline-block;\">View Full Results</a></p>\n  \n  <p>If you have any questions about your results, please contact your instructor or the CIMA team.</p>\n  \n  <p>Best regards,<br>The CIMA Team</p>\n`;\n\nreturn [{\n  json: {\n    student_email: student.email,\n    student_name: student.full_name,\n    assessment_title: results.assessment_title,\n    course_name: results.course_name,\n    score: results.score,\n    passed: results.passed,\n    correct_answers: results.correct_answers,\n    total_questions: results.total_questions,\n    subject: `Assessment Results: ${results.assessment_title} - ${results.score}%`,\n    html: emailHtml\n  }\n}];"
      },
      "id": "code-generate-result-email",
      "name": "Generate Result Email",
