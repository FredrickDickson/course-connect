      "type": "n8n-nodes-base.resend",
      "typeVersion": 1,
      "position": [2000, 300],
      "credentials": {
        "resendApi": {
          "id": "resend-api",
          "name": "Resend API"
        }
      }
    },
    {
      "parameters": {
        "operation": "insert",
        "table": "activity_log",
        "columns": {
          "assignment": [
            {
              "column": "user_id",
              "value": "={{ $json.user_id }}"
            },
            {
              "column": "action_type",
              "value": "written_assessment_graded"
            },
            {
              "column": "entity_type",
              "value": "written_assessment_submission"
            },
            {
              "column": "entity_id",
              "value": "={{ $json.submission_id }}"
            },
            {
              "column": "description",
              "value": "AI-graded written assessment: {{ $json.assessment_title }} - {{ $json.score }}%"
            },
            {
              "column": "metadata",
              "value": "{{ { score: $json.score, passed: $json.passed, grading_method: 'ai', ai_feedback_provided: true } }}"
            },
            {
              "column": "created_at",
              "value": "={{ $now }}"
            }
          ]
        },
        "additionalFields": {}
      },
      "id": "supabase-log-grading",
      "name": "Log AI Grading Activity",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [2220, 300],
      "credentials": {
        "supabaseApi": {
          "id": "supabase-service-role",
          "name": "Supabase Service Role"
        }
      }
    },
    {
      "parameters": {
        "channel": "#assessments",
        "text": "AI-graded assessment: {{ $json.student_name }} - {{ $json.assessment_title }} ({{ $json.score }}%) - {{ $json.passed ? 'PASSED' : 'FAILED' }}",
        "otherOptions": {}
      },
      "id": "slack-admin-notification",
      "name": "Notify Admin (Slack)",
      "type": "n8n-nodes-base.slack",
