            }
          ]
        },
        "additionalFields": {}
      },
      "id": "supabase-create-notification",
      "name": "Create Notification",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [2000, 300],
      "credentials": {
        "supabaseApi": {
          "id": "supabase-service-role",
          "name": "Supabase Service Role"
        }
      }
    },
    {
      "parameters": {
        "from": "community@thecima.org",
        "to": "={{ $('Get Author Profile').first().json.email }}",
        "subject": "AI instructor replied to your question",
        "html": "<h2>AI Instructor Response</h2><p>Dear {{ $('Get Author Profile').first().json.full_name }},</p><p>CIMA's AI instructor has responded to your question in the community forum:</p><h3>{{ $json.question_title }}</h3><p><strong>Category:</strong> {{ $json.question_category }}</p><div style=\"background: #f8f9fa; padding: 15px; border-radius: 5px; margin: 15px 0; border-left: 4px solid #007bff;\"><p>{{ $json.ai_reply.substring(0, 300) }}...</p></div><p><a href=\"https://cima.learn/community/posts/{{ $json.post_id }}\"><strong>View Full Response</strong></a></p><p>This is an automated response from our AI instructor system. Human instructors may also provide additional insights or follow up on your question.</p><p>Best regards,<br>The CIMA Team</p>",
        "options": {}
      },
