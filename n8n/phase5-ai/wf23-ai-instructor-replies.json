{
  "name": "WF23: AI instructor auto-replies -> community forum questions",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "forum-question-posted",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-forum-question",
      "name": "Forum Question Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "forum-question-posted"
    },
    {
      "parameters": {
        "jsCode": "// Process forum question webhook\nconst crypto = require('crypto');\n\nconst webhookSecret = $env.SUPABASE_WEBHOOK_SECRET;\nconst signature = $headers['x-webhook-secret'];\n\nif (signature !== webhookSecret) {\n  throw new Error('Invalid webhook signature');\n}\n\n// Check if this is a new forum_post insertion with question category\nconst record = $json.body.record;\nif (!record || $json.body.type !== 'INSERT' || record.table !== 'forum_posts') {\n  return []; // Not a new forum post\n}\n\n// Only process posts in question categories\nconst questionCategories = ['questions', 'course-help', 'technical-support', 'general-discussion'];\nif (!questionCategories.includes(record.category)) {\n  return []; // Not a question category\n}\n\n// Check if this looks like a question (contains ? or question words)\nconst questionWords = ['how', 'what', 'when', 'where', 'why', 'which', 'who', 'can', 'could', 'would', 'should', 'is', 'are', 'do', 'does'];\nconst title = record.title.toLowerCase();\nconst body = record.body.toLowerCase();\nconst hasQuestionWord = questionWords.some(word => title.includes(word) || body.includes(word));\nconst hasQuestionMark = title.includes('?') || body.includes('?');\n\nif (!hasQuestionWord && !hasQuestionMark) {\n  return []; // Doesn't look like a question\n}\n\nreturn [{\n  json: {\n    post_id: record.id,\n    title: record.title,\n    body: record.body,\n    author_id: record.user_id,\n    category: record.category,\n    created_at: record.created_at\n  }\n}];"
      },
      "id": "code-process-forum-question",
      "name": "Process Forum Question",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "operation": "select",
        "table": "profiles",
        "where": {
          "conditions": [
            {
              "column": "id",
              "condition": "equal",
              "value": "={{ $json.author_id }}",
              "combinator": "and"
            }
          ]
        },
        "additionalFields": {}
      },
      "id": "supabase-get-author-profile",
      "name": "Get Author Profile",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [680, 300],
      "credentials": {
        "supabaseApi": {
          "id": "supabase-service-role",
          "name": "Supabase Service Role"
        }
      }
    },
    {
      "parameters": {
        "operation": "select",
        "table": "forum_replies",
        "where": {
          "conditions": [
            {
              "column": "post_id",
              "condition": "equal",
              "value": "={{ $json.post_id }}",
              "combinator": "and"
            }
          ]
        },
        "additionalFields": {
          "limit": 1
        }
      },
      "id": "supabase-check-existing-replies",
      "name": "Check Existing Replies",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [900, 300],
      "credentials": {
        "supabaseApi": {
          "id": "supabase-service-role",
          "name": "Supabase Service Role"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "no-replies-yet",
              "leftValue": "={{ $json.length }}",
              "rightValue": "0",
              "operator": {
                "type": "number",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-no-replies-yet",
      "name": "No Replies Yet?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyContentType": "json",
        "jsonBody": "{\n  \"model\": \"gpt-3.5-turbo\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert instructor for the Center for International Mediators and Arbitrators (CIMA). Provide helpful, professional responses to student questions about international mediation, arbitration, and related topics. Be encouraging and educational. Keep responses concise but thorough. Always mention that this is an AI response and human instructors may provide additional insights.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Category: {{ $json.category }}\\n\\nQuestion: {{ $json.title }}\\n\\nDetails: {{ $json.body }}\\n\\nPlease provide a helpful response to this student's question. Include relevant concepts, practical advice, and suggest where they can learn more about this topic.\"\n    }\n  ],\n  \"max_tokens\": 800,\n  \"temperature\": 0.7\n}",
        "options": {}
      },
      "id": "openai-generate-reply",
      "name": "Generate AI Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1340, 300],
      "credentials": {
        "openAiApi": {
          "id": "openai-api-key",
          "name": "OpenAI API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Process AI reply and prepare for posting\nconst aiResponse = $json;\nconst question = $('Process Forum Question').first().json;\nconst author = $('Get Author Profile').first().json;\n\n// Extract the AI response content\nconst aiReplyContent = aiResponse.choices[0].message.content;\n\n// Add AI disclaimer and signature\nconst finalReply = `${aiReplyContent}\\n\\n---\\n\\n*This is an AI-generated response from CIMA's automated instructor system. Human instructors may provide additional insights or follow up on this response. If you need more detailed assistance, please tag @instructor in your reply.*`;\n\nreturn [{\n  json: {\n    post_id: question.post_id,\n    ai_reply: finalReply,\n    author_name: author.full_name,\n    question_title: question.title,\n    question_category: question.category\n  }\n}];"
      },
      "id": "code-process-ai-reply",
      "name": "Process AI Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "operation": "insert",
        "table": "forum_replies",
        "columns": {
