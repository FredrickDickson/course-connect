            },
            {
              "column": "metadata",
              "value": "{{ { flagged_categories: $json.flagged_categories, moderation_type: 'ai' } }}"
            },
            {
              "column": "created_at",
              "value": "={{ $now }}"
            }
          ]
        },
        "additionalFields": {}
      },
      "id": "supabase-log-moderation",
      "name": "Log Moderation Activity",
