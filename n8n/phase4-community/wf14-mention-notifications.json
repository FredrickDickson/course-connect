{
  "name": "WF14: User @mentioned in post -> in-app + email notification",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "forum-reply-created",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-forum-reply",
      "name": "Forum Reply Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "forum-reply-created"
    },
    {
      "parameters": {
        "jsCode": "// Process forum reply webhook\nconst crypto = require('crypto');\n\nconst webhookSecret = $env.SUPABASE_WEBHOOK_SECRET;\nconst signature = $headers['x-webhook-secret'];\n\nif (signature !== webhookSecret) {\n  throw new Error('Invalid webhook signature');\n}\n\n// Check if this is a new forum_reply insertion\nconst record = $json.body.record;\nif (!record || $json.body.type !== 'INSERT' || record.table !== 'forum_replies') {\n  return []; // Not a new forum reply\n}\n\nreturn [{\n  json: {\n    reply_id: record.id,\n    post_id: record.post_id,\n    body: record.body,\n    author_id: record.user_id,\n    created_at: record.created_at\n  }\n}];"
      },
      "id": "code-process-forum-reply",
      "name": "Process Forum Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "jsCode": "// Extract @mentions from reply body\nconst reply = $json;\n\n// Extract mentions using regex\nconst mentionRegex = /@([a-zA-Z0-9_]+)/g;\nconst mentions = [];\nlet match;\n\nwhile ((match = mentionRegex.exec(reply.body)) !== null) {\n  mentions.push(match[1]); // Get the username without @\n}\n\n// Remove duplicates\nconst uniqueMentions = [...new Set(mentions)];\n\nif (uniqueMentions.length === 0) {\n  return []; // No mentions found\n}\n\nreturn [{\n  json: {\n    ...reply,\n    mentions: uniqueMentions,\n    mention_count: uniqueMentions.length\n  }\n}];"
      },
      "id": "code-extract-mentions",
      "name": "Extract @Mentions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-mentions",
              "leftValue": "={{ $json.mention_count }}",
              "rightValue": "0",
              "operator": {
                "type": "number",
                "operation": "greaterThan"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "if-has-mentions",
      "name": "Has Mentions?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
