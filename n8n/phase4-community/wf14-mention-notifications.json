    {
      "parameters": {
        "operation": "insert",
        "table": "community_notifications",
        "columns": {
          "assignment": [
            {
              "column": "user_id",
              "value": "={{ $json.id }}"
            },
            {
              "column": "type",
              "value": "mention"
            },
            {
              "column": "title",
              "value": "You were mentioned in a discussion"
            },
            {
              "column": "content",
              "value": "@{{ $('Get Author Profile').first().json.username }} mentioned you in a reply to \"{{ $('Get Post Details').first().json.title }}\""
            },
            {
              "column": "entity_type",
              "value": "forum_reply"
            },
            {
              "column": "entity_id",
              "value": "={{ $json.reply_id }}"
            },
            {
              "column": "post_id",
              "value": "={{ $json.post_id }}"
            },
            {
              "column": "status",
              "value": "unread"
            },
