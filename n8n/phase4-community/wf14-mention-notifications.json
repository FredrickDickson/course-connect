      "id": "supabase-create-notification",
      "name": "Create In-App Notification",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [2220, 300],
      "credentials": {
        "supabaseApi": {
          "id": "supabase-service-role",
          "name": "Supabase Service Role"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Check if user has email notifications enabled for mentions\nconst user = $json;\nconst author = $('Get Author Profile').first().json;\nconst post = $('Get Post Details').first().json;\n\n// Check notification preferences\nconst notifications = user.notification_preferences || {};\nconst emailEnabled = notifications.mentions !== false;\n\nif (!emailEnabled) {\n  return [{ json: { skip_email: true, user_name: user.full_name } }];\n}\n\n// Generate notification email\nconst postUrl = `https://cima.learn/community/posts/${$json.post_id}#reply-${$json.reply_id}`;\n\n// Clean up the reply body for email (remove HTML, limit length)\nconst cleanBody = $json.body\n  .replace(/<[^>]*>/g, '') // Remove HTML tags\n  .replace(/@([a-zA-Z0-9_]+)/g, '@$1') // Keep mentions\n  .substring(0, 200) + ($json.body.length > 200 ? '...' : '');\n\nconst emailHtml = `\n  <h2>You Were Mentioned!</h2>\n  <p>Dear ${user.full_name},</p>\n  <p>@${author.username} mentioned you in a discussion on CIMA Community.</p>\n  \n  <h3>Discussion: ${post.title}</h3>\n  <p><strong>Category:</strong> ${post.category}</p>\n  \n  <h4>Reply Preview:</h4>\n  <blockquote>${cleanBody}</blockquote>\n  \n  <p><a href='${postUrl}'><strong>View Full Discussion</strong></a></p>\n  \n  <p>This is an automated notification. You can manage your notification preferences in your profile settings.</p>\n  \n  <p>Best regards,<br>The CIMA Team</p>\n`;\n\nreturn [{\n  json: {\n    user_email: user.email,\n    user_name: user.full_name,\n    author_name: author.full_name,\n    author_username: author.username,\n    post_title: post.title,\n    post_category: post.category,\n    post_url: postUrl,\n    subject: `@${author.username} mentioned you in \"${post.title}\"`,\n    html: emailHtml,\n    skip_email: false\n  }\n}];"
      },
      "id": "code-generate-email-notification",
      "name": "Generate Email Notification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2440, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
