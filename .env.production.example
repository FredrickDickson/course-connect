# CIMA Learning Platform - Production Environment
# Used for Vercel Production deployments

# Supabase Configuration (Production)
VITE_SUPABASE_URL=https://your-production-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-production-anon-key
VITE_SUPABASE_PROJECT_ID=your-production-project-id
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

# Database (Production)
DATABASE_URL=postgresql://postgres:password@db.your-production-project.supabase.co:5432/postgres

# Application (Production)
NODE_ENV=production
VITE_APP_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com

# Session Management (Production)
SESSION_SECRET=your-production-session-secret-min-32-characters

# Payment Gateway - Live Keys (Production)
PAYSTACK_SECRET_KEY=sk_live_...
VITE_PAYSTACK_PUBLIC_KEY=pk_live_...

# Email/Notifications (Production)
RESEND_API_KEY=re_...

# Certificate Generation API (for n8n workflow)
CERTIFICATE_API_KEY=your-certificate-api-secret-key

# n8n Workflow Integration
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/paystack-renewal
N8N_API_KEY=your-n8n-api-key

# File Upload (Production)
GOOGLE_CLOUD_STORAGE_BUCKET=your-production-bucket

# Production-specific flags
VITE_DEBUG_MODE=false
VITE_ENABLE_MOCK_PAYMENTS=false
VITE_ENVIRONMENT=production
