# CIMA Learning Platform - Local Development Environment
# Copy this to .env.local for your local development setup

# Supabase Configuration (Local)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Local)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Application (Local)
NODE_ENV=development
VITE_APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Session Management (Local)
SESSION_SECRET=your-local-session-secret-min-32-characters

# Payment Gateway - Test Keys (Local)
PAYSTACK_SECRET_KEY=sk_test_...
VITE_PAYSTACK_PUBLIC_KEY=pk_test_...

# Email/Notifications (Local - Optional)
RESEND_API_KEY=re_...

# File Upload (Local - Optional)
GOOGLE_CLOUD_STORAGE_BUCKET=your-local-bucket

# Development-only flags
VITE_DEBUG_MODE=true
VITE_ENABLE_MOCK_PAYMENTS=true
