# CIMA Learning Platform Environment Variables

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Database
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Application
NODE_ENV=development
SESSION_SECRET=your-session-secret-min-32-characters

# Production CORS (REQUIRED in production)
FRONTEND_URL=https://your-domain.com

# Payment Gateway (Paystack)
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...

# Email/Notifications (optional)
RESEND_API_KEY=re_...
INTERNAL_API_KEY=your-internal-api-key-min-32-characters

# Certificate Generation API (for n8n workflow)
CERTIFICATE_API_KEY=your-certificate-api-secret-key

# n8n Workflow Integration
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/paystack-renewal
N8N_API_KEY=your-n8n-api-key

# Frontend URL (used for callbacks and CORS)
VITE_APP_URL=https://your-domain.com

# Currency Conversion Rate (USD to GHS for Paystack payments)
USD_TO_GHS_RATE=11
VITE_USD_TO_GHS_RATE=11

# File Upload (optional - for cloud storage)
GOOGLE_CLOUD_STORAGE_BUCKET=your-bucket

# Mux Video Streaming
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
MUX_WEBHOOK_SIGNING_SECRET=your-mux-webhook-secret

# Zoom Integration
ZOOM_API_KEY=your-zoom-api-key
ZOOM_API_SECRET=your-zoom-api-secret
ZOOM_REDIRECT_URI=http://localhost:5173/api/zoom/auth/callback
ZOOM_WEBHOOK_SECRET=your-zoom-webhook-secret
ZOOM_SDK_KEY=your-zoom-sdk-key
ZOOM_SDK_SECRET=your-zoom-sdk-secret

# Frontend URL for Mux CORS
CLIENT_URL=http://localhost:5173
